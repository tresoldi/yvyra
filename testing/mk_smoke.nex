#NEXUS

[ Minimal Mk smoke test. Runs fast, just checks start-and-finish. ]

Begin data;
    Dimensions ntax=4 nchar=5;
    Format datatype=standard symbols="0 1" missing=? gap=-;
    Matrix
        A  0 0 1 0 1
        B  0 1 1 0 0
        C  1 1 0 1 0
        D  1 0 0 1 1
    ;
End;

Begin yvyra;
    set autoclose=yes nowarnings=yes;
    lset coding=variable;
    set seed=42;
    mcmcp nrun=1 nchain=1 ngen=1000 samplefr=10;
    mcmcp printfr=500 diagnfr=1000;
    mcmc;
End;
